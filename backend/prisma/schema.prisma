// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prismag"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  manager
  employee
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(employee)
  createdAt DateTime @default(now())
}